{
  "name": "openmagic",
  "version": "0.43.2",
  "description": "AI-powered coding toolbar for any web application. Select elements, capture context, and let AI modify your codebase in real-time.",
  "type": "module",
  "bin": {
    "openmagic": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:toolbar": "tsup src/toolbar/index.ts --no-config --format iife --global-name OpenMagicToolbar --platform browser --target es2020 --out-dir dist/toolbar --minify",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"*.config.ts\"",
    "test": "vitest run",
    "test:smoke": "npm run build && node scripts/smoke-test.mjs",
    "test:browser": "npm run build && node scripts/browser-smoke-test.mjs",
    "check:pack": "npm pack --dry-run",
    "check:all": "npm run typecheck && npm run lint && npm test && npm run test:smoke && npm run test:browser && npm run check:pack",
    "prepublishOnly": "npm run build && npm run build:toolbar"
  },
  "keywords": [
    "ai",
    "llm",
    "toolbar",
    "development",
    "vibe-coding",
    "openai",
    "anthropic",
    "gemini",
    "developer-tools",
    "code-modification",
    "element-selector",
    "screenshot"
  ],
  "author": "Khalid Almuraee <Khalid.s.almuraee@gmail.com> (https://github.com/kalmuraee)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kalmuraee/OpenMagic.git"
  },
  "homepage": "https://kalmuraee.github.io/OpenMagic/",
  "bugs": {
    "url": "https://github.com/Kalmuraee/OpenMagic/issues"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "http-proxy": "^1.18.1",
    "nanospinner": "^1.2.2",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "terminal-link": "^5.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/http-proxy": "^1.17.15",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "eslint": "^10.3.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
